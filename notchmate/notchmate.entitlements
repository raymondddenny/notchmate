<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Ad-hoc / default entitlements. Only NON-restricted entitlements may live here:
	     a restricted entitlement (e.g. keychain-access-groups) requires a real Apple
	     certificate chain, which ad-hoc signing lacks, and AMFI then kills the app at
	     launch on macOS 26 (RBS Code=5 / POSIX 163). The data-protection keychain that
	     keychain-access-groups would unlock is only used in Developer ID builds; ad-hoc
	     builds use the login keychain (see SpotifyKeychain, #if ADHOC_SIGNING).
	     The Developer ID variant lives in notchmate-devid.entitlements. -->
	<key>com.apple.security.automation.apple-events</key>
	<true/>
</dict>
</plist>
